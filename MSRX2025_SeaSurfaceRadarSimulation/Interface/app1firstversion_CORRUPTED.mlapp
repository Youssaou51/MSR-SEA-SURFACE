% ── Créer la grille de la ligne 2 ──
dropGrid = uigridlayout(app.GridLayout30);
dropGrid.ColumnWidth   = {'1x', 80, 25, 80, 30, '1x', 160};
dropGrid.RowHeight     = {'1x'};
