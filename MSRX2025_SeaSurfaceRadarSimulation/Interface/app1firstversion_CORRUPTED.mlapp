% ── Connecter les champs n_s ──
app.LengthmEditField.ValueChangedFcn = @(~,~) app.updateNs();
app.SamplesperwavelengthEditField_2.ValueChangedFcn = @(~,~) app.updateNs();
% ── Onglet 3 : fréquence → label + n_s ──
