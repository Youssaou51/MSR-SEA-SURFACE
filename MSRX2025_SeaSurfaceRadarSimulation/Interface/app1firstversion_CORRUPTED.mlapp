app.RangeEndDropDown.Layout.Row      = 1;
app.RangeEndDropDown.Layout.Column   = 4;
app.RangeEndDropDown.ValueChangedFcn = @(~,~) app.onRangeDropDownChanged();

% ── Col 5 : espace ──
sp = uilabel(dropGrid);
