% ── Col 1 : Label "Profile range:" ──
rangeLabel = uilabel(dropGrid);
rangeLabel.Text                = 'Profile range:';
rangeLabel.FontWeight          = 'bold';
rangeLabel.FontSize            = 11;
rangeLabel.HorizontalAlignment = 'right';
rangeLabel.Layout.Row          = 1;
